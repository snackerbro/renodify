# ─────────────────────────────────────────────────────────────────────────
# Renodify environment variables
# Copy to `.env.local` for local dev. In Vercel, add these in
# Project → Settings → Environment Variables. See SETUP.md for the full guide.
# ─────────────────────────────────────────────────────────────────────────

# Public site URL (used for canonical URLs, sitemap, OG tags, Stripe redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase — Project Settings → API Keys
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Publishable key (sb_publishable_...) — browser-safe, RLS enforced.
# (Legacy "anon" key also works here if you haven't migrated.)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
# Secret key (sb_secret_...) — server-only, NEVER expose to the browser.
# Used by the admin client + Stripe webhooks. (Legacy "service_role" also works.)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# Stripe — set up later (Dashboard → Developers → API keys)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Recurring Price IDs for the three vendor plans (Dashboard → Products)
NEXT_PUBLIC_STRIPE_PRICE_BASIC=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_SILVER=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_GOLD=price_xxx
